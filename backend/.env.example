# backend/.env.example

# 数据库连接
DATABASE_URL="postgresql://postgres:password@localhost:5432/quickchat?schema=public"

# 应用配置
NODE_ENV=development
PORT=3001

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS（生产环境 NODE_ENV=production 时，须包含实际前端地址，例如 http://192.168.1.5:3000）
FRONTEND_URL=http://localhost:3000
